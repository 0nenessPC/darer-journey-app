{
  "name": "darer-journey",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "npx playwright test --project e2e",
    "test:e2e:ui": "npx playwright test --project e2e --ui",
    "test:e2e:headed": "npx playwright test --project e2e --headed",
    "test:ai": "npx playwright test --project ai",
    "test:ai:ui": "npx playwright test --project ai --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "openai": "^6.34.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
